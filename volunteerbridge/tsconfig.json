{
	"compilerOptions": {
		"target": "ES2021",
		"lib": ["dom", "dom.iterable", "es2021"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "CommonJS",
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": ".",
		"types": ["node"],
		"paths": {
			"@/*": ["./*"]
		},
		"ignoreDeprecations": "6.0"
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
